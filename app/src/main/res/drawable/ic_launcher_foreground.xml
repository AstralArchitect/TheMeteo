<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background Glow centered -->
    <path
        android:pathData="M54,54m-45,0a45,45 0,1 1,90 0a45,45 0,1 1,-90 0"
        android:alpha="0.15">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="45">
                <item android:color="#FFFFFF" android:offset="0" />
                <item android:color="#00FFFFFF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Centered Content Group -->
    <group
        android:translateX="2"
        android:translateY="-2">

        <!-- Main Cloud Group - Calculated translation to center the 1.6x scaled SVG -->
        <group
            android:translateX="0"
            android:translateY="0"
            android:scaleX="1.6"
            android:scaleY="1.6">
            
            <!-- Cloud Shadow -->
            <path
                android:pathData="m 47.7,35.4 c 0,-4.6 -3.7,-8.2 -8.2,-8.2 -1,0 -1.9,0.2 -2.8,0.5 -0.3,-3.4 -3.1,-6.2 -6.6,-6.2 -3.7,0 -6.7,3 -6.7,6.7 0,0.8 0.2,1.6 0.4,2.3 -0.3,-0.1 -0.7,-0.1 -1,-0.1 -3.7,0 -6.7,3 -6.7,6.7 0,3.6 2.9,6.6 6.5,6.7 h 17.2 c 4.4,-0.5 7.9,-4 7.9,-8.4 z"
                android:fillColor="#22000000"
                android:translateX="-0.5"
                android:translateY="3.5" />

            <!-- Main Cloud Body -->
            <path
                android:pathData="m 47.7,35.4 c 0,-4.6 -3.7,-8.2 -8.2,-8.2 -1,0 -1.9,0.2 -2.8,0.5 -0.3,-3.4 -3.1,-6.2 -6.6,-6.2 -3.7,0 -6.7,3 -6.7,6.7 0,0.8 0.2,1.6 0.4,2.3 -0.3,-0.1 -0.7,-0.1 -1,-0.1 -3.7,0 -6.7,3 -6.7,6.7 0,3.6 2.9,6.6 6.5,6.7 h 17.2 c 4.4,-0.5 7.9,-4 7.9,-8.4 z"
                android:translateX="-1.5"
                android:translateY="2.5">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="30"
                        android:startY="20"
                        android:endX="30"
                        android:endY="45">
                        <item android:color="#FFFFFF" android:offset="0" />
                        <item android:color="#E0E0E0" android:offset="1" />
                    </gradient>
                </aapt:attr>
            </path>

            <!-- AstralArchitect "A" Signature (Positioned relative to centered cloud) -->
            <group
                android:translateX="-1.5"
                android:translateY="2.5">
                <path
                    android:pathData="M33,30 L29,38 M33,30 L37,38 M30.5,35 L35.5,35"
                    android:strokeColor="#455A64"
                    android:strokeWidth="1.2"
                    android:strokeLineCap="round"
                    android:strokeLineJoin="round"
                    android:alpha="0.6" />
            </group>
        </group>

        <!-- Centered Rain Drops below the cloud -->
        <group 
            android:translateX="-2.5"
            android:translateY="-0.5">
            <path
                android:pathData="M40,75 L40,80"
                android:strokeColor="#81D4FA"
                android:strokeWidth="2.5"
                android:strokeLineCap="round"
                android:alpha="0.6" />
            <path
                android:pathData="M54,78 L54,83"
                android:strokeColor="#81D4FA"
                android:strokeWidth="2.5"
                android:strokeLineCap="round"
                android:alpha="0.6" />
            <path
                android:pathData="M68,75 L68,80"
                android:strokeColor="#81D4FA"
                android:strokeWidth="2.5"
                android:strokeLineCap="round"
                android:alpha="0.6" />
        </group>
    </group>

</vector>