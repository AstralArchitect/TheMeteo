<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".TheMeteo"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme.Compose">

        <uses-library
            android:name="org.apache.http.legacy"
            android:required="false" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity android:name=".forecastMainActivity.NewDesignActivity"
            android:exported="true"
            android:theme="@style/AppTheme.Compose">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />

            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_activity_settings_activity.kt"
            android:theme="@style/AppTheme.Compose" />
        <activity
            android:name=".forecastMainActivity.ForecastMainActivity"
            android:exported="true"
            android:theme="@style/AppTheme.Compose"/>
        <activity
            android:name=".dayChoserActivity.DayChooserActivity"
            android:exported="false"
            android:label="@string/title_activity_temp_graphs"
            android:theme="@style/AppTheme.Compose" />
        <activity
            android:name=".dayGraphsActivity.DayGraphsActivity"
            android:exported="false"
            android:label="@string/title_activity_day_graphs"
            android:theme="@style/AppTheme.Compose" />
        <activity
            android:name=".satImgs.DocActivity"
            android:exported="false"
            android:label="@string/title_activity_full_screen_sat_image"
            android:theme="@style/AppTheme.Compose" />
        <activity
            android:name=".satImgs.MapActivity"
            android:exported="true"
            android:label="MapActivity"
            android:theme="@style/AppTheme" />
    </application>

</manifest>